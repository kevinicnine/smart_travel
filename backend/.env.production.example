PORT=8080
SMART_TRAVEL_EXPOSE_CODES=false
SMART_TRAVEL_DATA_DIR=/app/data

ADMIN_USERNAME=change-me
ADMIN_PASSWORD=change-me
ADMIN_TOKEN=change-me-to-a-long-random-token

GOOGLE_MAPS_API_KEY=change-me
GOOGLE_PLACES_SERVER_API_KEY=change-me

# Optional: LINE integration
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
LINE_ADD_FRIEND_URL=

# Optional: notification providers
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_FROM_NAME=Smart Travel
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Optional: database. Leave unset to use JSON file at /app/data/db.json
DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_SSL=true

# Optional: LLM
LLM_PROVIDER=gemini
GEMINI_API_KEYS=
GEMINI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

# Required when reminder-cron service is enabled
REMINDER_CRON_TOKEN=change-me-to-a-random-token
REMINDER_NEXT_STOP_MINUTES=20
REMINDER_NEXT_STOP_GRACE_MINUTES=30
REMINDER_EVENING_START_HOUR=20
REMINDER_EVENING_END_HOUR=23
